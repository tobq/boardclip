{
  "name": "boardclip",
  "productName": "BoardClip",
  "version": "2.1.1",
  "description": "Cross-platform clipboard history tray app with numpad quick-paste and native cloud sync",
  "author": "BoardClip contributors",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/clip-search.test.js && node test/ai-search-agent.test.js && node test/clipboard-model.test.js && node test/ensure-directory.test.js && node test/control-auth.test.js && node test/control-channel.test.js && node test/mcp-core.test.js && node test/mcp-installers.test.js && node test/mcp-helper-smoke.test.js && node test/retention.test.js && node test/backup.test.js && node test/editor-find.test.js && node test/multiselect.test.js && node test/numpad-paste.test.js && node test/ui-parity.test.js && node test/ui-tokens.test.js",
    "sync:icons": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-icons.ps1",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis portable --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never"
  },
  "build": {
    "appId": "app.boardclip.desktop",
    "productName": "BoardClip",
    "icon": "assets/boardclip-icon.png",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "mcp-approval.html",
      "mcp-approval-preload.js",
      "package.json",
      "lib/**",
      "mcp/**",
      "site/shared/**",
      "assets/boardclip-icon.png",
      "icon.png",
      "icon@2x.png"
    ],
    "extraResources": [
      {
        "from": "icon.png",
        "to": "icon.png"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/boardclip-icon.ico",
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "assets/boardclip-icon.png",
      "maintainer": "BoardClip contributors <hello@boardclip.app>",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  },
  "devDependencies": {
    "codemirror": "^5.65.21",
    "diff-match-patch": "^1.0.5",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "koffi": "^2.15.6",
    "zod": "^4.4.3"
  }
}
